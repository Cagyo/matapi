{
  "name": "home-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Home automation and security monitoring worker (NestJS + grammY) for Raspberry Pi",
  "homeWorkerRelease": {
    "target": "linux-arm64-glibc"
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test,scripts}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/system/infrastructure/migrate.entry.js",
    "db:studio": "drizzle-kit studio",
    "dev:seed": "ts-node scripts/dev-seed.ts",
    "dev:reset": "ts-node scripts/dev-seed.ts --reset",
    "dev:deploy": "bash scripts/dev-deploy.sh",
    "dev:deploy:reset": "bash scripts/dev-deploy.sh --reset",
    "dev:update": "bash scripts/dev-update.sh",
    "dev:update:reset": "bash scripts/dev-update.sh --reset",
    "release:candidate": "node scripts/release/build-candidate.mjs"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/conversations": "^2.0.1",
    "@grammyjs/runner": "^2.0.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "better-sqlite3": "^11.7.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "grammy": "^1.34.0",
    "mqtt": "^5",
    "pigpio-client": "^1.5.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serialport": "^12.0.0",
    "tar-stream": "^3.2.0",
    "yaml": "^2.7.0",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.10",
    "@types/tar-stream": "^3.1.4",
    "@types/yauzl": "^3.4.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
