# Required
# Set NODE_ENV=development in local dev environments to enable dev simulator & mock drivers
NODE_ENV=production
TELEGRAM_BOT_TOKEN=
CLAIM_ADMIN_TOKEN=
DATABASE_PATH=/opt/home-worker/data/worker.db

# Display
TIMEZONE=Europe/Kyiv
DATE_FORMAT=DD.MM.YYYY
TIME_FORMAT=HH:mm:ss
DATETIME_FORMAT=DD.MM.YYYY HH:mm
# Optional SSH host/IP shown in admin setup prompts. Leave blank to auto-detect
# the first usable local IPv4 address.
HOME_WORKER_SSH_HOST=

# Heartbeat
HEARTBEAT_URL=
HEARTBEAT_INTERVAL_MS=300000

# Retention
EVENT_RETENTION_DAYS=30
LOG_RETENTION_DAYS=30

# Event ingress (raw callbacks before SQLite persistence)
EVENT_MAX_CONCURRENCY=4
EVENT_MAX_PENDING=500

# Durable SQLite event queue. At capacity, the oldest unsent event is dropped
# before the newest is accepted; sent events are never evicted.
EVENT_MAX_UNSENT=500

# Sensor defaults
DEFAULT_DEBOUNCE_MS=10000
DEFAULT_SEVERITY=info

# pigpiod (digital GPIO)
PIGPIOD_HOST=localhost
PIGPIOD_PORT=8888

# CO2 defaults
CO2_READ_INTERVAL_MS=5000
CO2_FLUSH_INTERVAL_MS=60000
CO2_WARNING_PPM=800
CO2_CRITICAL_PPM=1200

# Motion / Camera
MOTION_VIDEO_SEGMENT_SEC=30
MOTION_LOCAL_DIR=/home/pi/motion/videos
# Port the worker's loopback HTTP server listens on. Current installed
# motion.conf hooks still use the default 4000; if you change this, update
# /etc/motion/motion.conf hook URLs too.
MOTION_HOOK_PORT=4000
# systemd unit name the worker starts/stops via sudo.
MOTION_SYSTEMD_UNIT=motion
# How often the watcher checks the daemon (ms).
MOTION_HEALTH_INTERVAL_MS=60000
# Snapshot source. Uncomment WITH a value to pin one source; keep commented
# otherwise — dotenv turns `KEY=` into the empty string, which the snapshot
# adapter would use as a (broken) ffmpeg input. Default behaviour (after the
# motion-runtime plan) is Motion's MJPEG stream, then the raw device.
# Per-camera override: MOTION_SNAPSHOT_SOURCE_<CAMERAID>=...
# MOTION_SNAPSHOT_SOURCE=http://127.0.0.1:8081
# Force adapter mode: real | stub (default: real on Linux, stub elsewhere).
# CAMERA_MODE=real

# Google Drive
GDRIVE_REMOTE_NAME=gdrive
GDRIVE_REMOTE_PATH=home-security/motion
GDRIVE_CLEANUP_MIN_AGE_DAYS=30

# Cleanup thresholds
DISK_WARN_PERCENT=70
DISK_CRITICAL_PERCENT=80
DISK_EMERGENCY_PERCENT=95
GDRIVE_CLEANUP_PERCENT=80

# Backup
BACKUP_CRON=0 3 * * *
BACKUP_LOCAL_PATH=/opt/home-worker/data/backup.db
BACKUP_TO_GDRIVE=true

# rclone
RCLONE_BW_LIMIT=1M
RCLONE_TRANSFERS=2

# PM2
PM2_MAX_MEMORY_RESTART=512M
PM2_MAX_RESTARTS=10

# Dev simulator — served on the worker's loopback HTTP port (MOTION_HOOK_PORT)
# at /dev/simulate when NODE_ENV=development. Value kept for documentation;
# the panel reuses the shared HTTP server rather than binding its own port.
DEV_SIMULATOR_PORT=4000

# ── MQTT Sensors ──────────────────────────────────
# Per-sensor MQTT config is stored in the DB sensor record.
# These are global defaults applied when a sensor doesn't specify its own.
# Reconnect delay must be an integer from 1000 to 300000 ms; an invalid
# MQTT_DEFAULT_RECONNECT_MS falls back to 5000 ms so it cannot disable recovery.
MQTT_DEFAULT_BROKER_URL=mqtt://localhost:1883
MQTT_DEFAULT_QOS=0
MQTT_DEFAULT_RECONNECT_MS=5000
# Emit one sensor error after this many continuous milliseconds offline or closed.
# A positive integer is required; invalid values fall back to 60000 ms.
MQTT_OFFLINE_ALERT_MS=60000

# ── Camera Sensors ────────────────────────────────
# dotenv does NOT expand $HOME — leave unset to default to ~/.matapi/camera
# (resolved via os.homedir() in src/sensors/infrastructure/camera.config.ts).
# CAMERA_STORAGE_PATH=/home/homeworker/.matapi/camera
FFMPEG_PATH=ffmpeg

# ── OTA / update ──────────────────────────────────
# Optional pin for the branch OTA checks against and applies from. Leave
# commented to auto-detect origin's default branch (origin/HEAD, then
# master/main probes) — the worker and update.sh resolve it identically.
# HOME_WORKER_GIT_BRANCH=master
